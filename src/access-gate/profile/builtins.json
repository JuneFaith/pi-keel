{
  "defaultProfile": "plan",
  "profiles": {
    "file-read": {
      "description": "Read explicitly targeted files in projectRoot; deny directory listing, search, writes, and unclassified shell commands.",
      "shellPolicy": {
        "readOnly": "allow",
        "mutating": "deny",
        "unclassified": "deny"
      },
      "pathPolicy": {
        "default": { "read": "deny", "list": "deny", "search": "deny", "write": "deny" },
        "rules": [
          { "path": "project/**", "read": "allow" }
        ]
      }
    },
    "project-read": {
      "description": "Read and search projectRoot; deny writes, external paths, and unclassified shell commands.",
      "shellPolicy": {
        "readOnly": "allow",
        "mutating": "deny",
        "unclassified": "deny"
      },
      "pathPolicy": {
        "default": { "read": "deny", "list": "deny", "search": "deny", "write": "deny" },
        "rules": [
          { "path": "project/**", "read": "allow", "list": "allow", "search": "allow" }
        ]
      }
    },
    "research": {
      "description": "Read projectRoot and the staging directory; unclassified shell commands require one-time approval.",
      "extends": ["project-read"],
      "shellPolicy": {
        "mutating": "ask",
        "unclassified": "ask"
      },
      "pathPolicy": {
        "rules": [
          { "path": "staging/**", "read": "allow", "list": "allow", "search": "allow", "write": "allow" }
        ]
      }
    },
    "plan": {
      "description": "Read and search projectRoot; write project task and domain documents.",
      "extends": ["project-read"],
      "pathPolicy": {
        "rules": [
          { "path": "project/docs/**", "write": "allow" },
          { "path": "project/CONTEXT.md", "write": "allow" }
        ]
      }
    },
    "safe-write": {
      "description": "Read projectRoot and write only the configured safe source and test paths.",
      "extends": ["project-read"],
      "shellPolicy": {
        "mutating": "ask",
        "unclassified": "ask"
      },
      "pathPolicy": {
        "rules": [
          { "path": "project/src/**", "write": "allow" },
          { "path": "project/tests/**", "write": "allow" }
        ]
      }
    },
    "project-write": {
      "description": "Read and write projectRoot; known mutating shell commands are allowed and unclassified commands require approval.",
      "extends": ["project-read"],
      "shellPolicy": {
        "mutating": "allow",
        "unclassified": "ask"
      },
      "pathPolicy": {
        "rules": [
          { "path": "project/**", "write": "allow" }
        ]
      }
    },
    "guarded-write": {
      "description": "Read and write projectRoot; every known mutation and unclassified shell command requires one-time approval.",
      "extends": ["project-read"],
      "shellPolicy": {
        "mutating": "ask",
        "unclassified": "ask"
      },
      "pathPolicy": {
        "rules": [
          { "path": "project/**", "write": "ask" }
        ]
      }
    }
  }
}
