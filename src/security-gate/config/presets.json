{
  "presets": {
    "strict": {
      "level": "strict",
      "permission": {
        "*": "ask",
        "hardPath": [".env", ".env.*", "*.env", "*.env.example", "*.pem", "*.key", "*.pfx", "*.p12", "*.ppk", "*.cred", "*.credentials", ".netrc", ".npmrc", ".pypirc", "~/.ssh/*", "~/.aws/*", "~/.gnupg/*", "~/.kube/*", "~/.docker/config.json", "~/.config/gcloud/*", "**/id_rsa*", "**/id_ed25519*", "**/id_ecdsa*", "/etc/passwd", "/etc/shadow", "**/.git/config"],
        "path": {
          "*": "allow",
          ".env": "deny", ".env.*": "deny", "*.env": "deny",
          "*.pem": "deny", "*.key": "deny", "*.pfx": "deny", "*.p12": "deny", "*.ppk": "deny",
          "*.cred": "deny", "*.credentials": "deny",
          ".netrc": "deny", ".npmrc": "deny", ".pypirc": "deny",
          "~/.ssh/*": "deny", "~/.ssh/config": "allow",
          "~/.aws/*": "deny", "~/.gnupg/*": "deny",
          "~/.kube/*": "deny", "~/.docker/config.json": "deny", "~/.config/gcloud/*": "deny",
          "**/id_rsa*": "deny", "**/id_ed25519*": "deny", "**/id_ecdsa*": "deny",
          "/etc/passwd": "deny", "/etc/shadow": "deny", "/etc/hosts": "deny",
          "**/.git/config": "deny", "*.env.example": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "ask", "*.lock": "deny", ".env": "deny", ".env.*": "deny", "src/**": "allow", "tests/**": "allow" },
        "edit": { "*": "ask", "*.lock": "deny", ".env": "deny", ".env.*": "deny", "src/**": "allow", "tests/**": "allow" },
        "external_directory": "ask",
        "bash": {}
      }
    },

    "standard": {
      "level": "standard",
      "permission": {
        "*": "ask",
        "hardPath": [".env", ".env.*", "*.env", "*.env.example", "*.pem", "*.key", "*.pfx", "*.p12", "*.ppk", "*.cred", "*.credentials", ".netrc", ".npmrc", ".pypirc", "~/.ssh/*", "~/.aws/*", "~/.gnupg/*", "~/.kube/*", "~/.docker/config.json", "~/.config/gcloud/*", "**/id_rsa*", "**/id_ed25519*", "**/id_ecdsa*", "/etc/passwd", "/etc/shadow", "**/.git/config"],
        "path": {
          "*": "allow",
          ".env": "deny", ".env.*": "deny", "*.env": "deny",
          "*.pem": "deny", "*.key": "deny", "*.pfx": "deny", "*.p12": "deny", "*.ppk": "deny",
          "*.cred": "deny", "*.credentials": "deny",
          ".netrc": "deny", ".npmrc": "deny", ".pypirc": "deny",
          "~/.ssh/*": "deny", "~/.ssh/config": "allow",
          "~/.aws/*": "deny", "~/.gnupg/*": "deny",
          "~/.kube/*": "deny", "~/.docker/config.json": "deny", "~/.config/gcloud/*": "deny",
          "**/id_rsa*": "deny", "**/id_ed25519*": "deny", "**/id_ecdsa*": "deny",
          "/etc/passwd": "deny", "/etc/shadow": "deny",
          "**/.git/config": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "ask", "*.lock": "deny" },
        "edit": { "*": "ask", "*.lock": "deny" },
        "external_directory": "ask",
        "bash": {}
      }
    },

    "permissive": {
      "level": "permissive",
      "permission": {
        "*": "allow",
        "hardPath": [".env", "*.pem", "*.key", "*.ppk", ".netrc", "**/.git/config"],
        "path": {
          "*": "allow",
          ".env": "deny", "*.pem": "deny", "*.key": "deny",
          "*.ppk": "deny", ".netrc": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "allow" },
        "edit": { "*": "allow" },
        "external_directory": "allow",
        "bash": {}
      }
    }
  }
}
