{
  "$schema": "../schemas/security-config.schema.json",
  "presets": {
    "strict": {
      "level": "strict",
      "sandbox": {
        "enabled": true,
        "filesystem": {
          "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.kube", "~/.config/gcloud", "/etc/passwd", "/etc/shadow", "/etc/hosts"],
          "allowWrite": [".", "/tmp"],
          "denyWrite": [".env", ".env.*", "*.pem", "*.key", "*.pfx", "*.p12", "*.ppk", "*.env.example"],
          "allowRead": ["~/.ssh/config"]
        },
        "network": {
          "allowNetwork": true,
          "allowedDomains": ["github.com", "*.github.com", "raw.githubusercontent.com", "registry.npmjs.org", "*.npmjs.org", "registry.yarnpkg.com"]
        }
      },
      "permission": {
        "*": "ask",
        "path": {
          "*": "allow",
          ".env": "deny", ".env.*": "deny", "*.env": "deny",
          "*.pem": "deny", "*.key": "deny", "*.pfx": "deny", "*.p12": "deny", "*.ppk": "deny",
          "*.cred": "deny", "*.credentials": "deny",
          ".netrc": "deny", ".npmrc": "deny", ".pypirc": "deny",
          "~/.ssh/*": "deny", "~/.ssh/config": "allow",
          "~/.aws/*": "deny", "~/.gnupg/*": "deny",
          "~/.kube/*": "deny", "~/.docker/config.json": "deny", "~/.config/gcloud/*": "deny",
          "**/id_rsa*": "deny", "**/id_ed25519*": "deny", "**/id_ecdsa*": "deny",
          "/etc/passwd": "deny", "/etc/shadow": "deny", "/etc/hosts": "deny",
          "**/.git/config": "deny", "*.env.example": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "ask", "*.lock": "deny", ".env": "deny", ".env.*": "deny", "src/**": "allow", "tests/**": "allow" },
        "edit": { "*": "ask", "*.lock": "deny", ".env": "deny", ".env.*": "deny", "src/**": "allow", "tests/**": "allow" },
        "external_directory": "ask"
      },
      "audit": { "enabled": true, "logPath": "~/.pi/agent/logs/security-audit.jsonl", "redactSecrets": true }
    },

    "standard": {
      "level": "standard",
      "sandbox": {
        "enabled": false,
        "filesystem": {
          "denyRead": [], "allowWrite": [".", "/tmp"], "denyWrite": [], "allowRead": []
        },
        "network": { "allowNetwork": true, "allowedDomains": [] }
      },
      "permission": {
        "*": "ask",
        "path": {
          "*": "allow",
          ".env": "deny", ".env.*": "deny", "*.env": "deny",
          "*.pem": "deny", "*.key": "deny", "*.pfx": "deny", "*.p12": "deny", "*.ppk": "deny",
          "*.cred": "deny", "*.credentials": "deny",
          ".netrc": "deny", ".npmrc": "deny", ".pypirc": "deny",
          "~/.ssh/*": "deny", "~/.ssh/config": "allow",
          "~/.aws/*": "deny", "~/.gnupg/*": "deny",
          "~/.kube/*": "deny", "~/.docker/config.json": "deny", "~/.config/gcloud/*": "deny",
          "**/id_rsa*": "deny", "**/id_ed25519*": "deny", "**/id_ecdsa*": "deny",
          "/etc/passwd": "deny", "/etc/shadow": "deny",
          "**/.git/config": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "ask", "*.lock": "deny" },
        "edit": { "*": "ask", "*.lock": "deny" },
        "external_directory": "ask"
      },
      "audit": { "enabled": true, "logPath": "~/.pi/agent/logs/security-audit.jsonl", "redactSecrets": true }
    },

    "permissive": {
      "level": "permissive",
      "sandbox": {
        "enabled": false,
        "filesystem": {
          "denyRead": [], "allowWrite": [".", "/tmp"], "denyWrite": [], "allowRead": []
        },
        "network": { "allowNetwork": true, "allowedDomains": [] }
      },
      "permission": {
        "*": "allow",
        "path": {
          "*": "allow",
          ".env": "deny", "*.pem": "deny", "*.key": "deny",
          "*.ppk": "deny", ".netrc": "deny"
        },
        "read": { "*": "allow" },
        "write": { "*": "allow" },
        "edit": { "*": "allow" },
        "external_directory": "allow"
      },
      "audit": { "enabled": false, "logPath": "~/.pi/agent/logs/security-audit.jsonl", "redactSecrets": true }
    }
  }
}
